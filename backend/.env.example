# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
LOG_LEVEL=info

# MongoDB (required)
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/vjfashions
# Set to true only for local dev if Atlas TLS fails
# MONGODB_TLS_INSECURE=false

# JWT secrets (required — use long random strings in production)
JWT_ADMIN_SECRET=My_rules_yevadraNuvvu_amit_admin
JWT_USER_SECRET=My_rules_yevadraNuvvu_amit_user

# Store details (optional — defaults are set in storeRoutes.js)
STORE_ADDRESS=Ground First And Second Floor, Door No 14, RR Road, Muntha vari Centre, Chirala, Andhra Pradesh 523155
STORE_PHONE=+917799540006
STORE_HOURS=10:00 AM – 9:00 PM (Daily)
STORE_MAP_EMBED_URL=https://www.google.com/maps?q=Ground+First+And+Second+Floor,+Door+No+14,+RR+Road,+Muntha+vari+Centre,+Chirala,+Andhra+Pradesh+523155&output=embed
WHATSAPP_NUMBER=917799540006

# Upstash Redis (optional — leave as placeholders to disable cache)
UPSTASH_REDIS_REST_URL=your_upstash_redis_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token

# Cloudinary (required for production image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# SMTP email (optional — dev mode logs verify links to console)
SMTP_HOST=your_smtp_host
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM=VJ Fashions <noreply@vjfashions.com>

# Google Gemini — AI chatbot (get key at https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key
# GEMINI_MODEL=gemini-2.0-flash
